@model DiplomaManagementSystem.Web.Areas.Admin.Models.DefenceSessionDetailsViewModel
@{
    ViewData["Title"] = "Сесія захисту";
    bool canManageGroups = Model.Status == DiplomaManagementSystem.Domain.Enums.DefenceSessionStatus.Active;
}

<h2>Сесія захисту</h2>

<partial name="_TempDataAlerts"/>

<dl class="row">
    <dt class="col-sm-3">Рік</dt>
    <dd class="col-sm-9">@Model.Year</dd>
    <dt class="col-sm-3">Тип</dt>
    <dd class="col-sm-9">@Model.TypeDisplay</dd>
    <dt class="col-sm-3">Семестр</dt>
    <dd class="col-sm-9">@(Model.Semester?.ToString() ?? "—")</dd>
    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@Model.StatusDisplay</dd>
    <dt class="col-sm-3">Студентів</dt>
    <dd class="col-sm-9">@Model.DiplomaCount</dd>
</dl>

<div class="session-row-actions justify-content-start mb-3">
    @if (canManageGroups)
    {
        <a class="btn btn-outline-primary" asp-controller="StudyGroups" asp-action="Create" asp-route-defenceSessionId="@Model.Id">Нова група</a>
    }
    <a class="btn btn-outline-success" asp-controller="Students" asp-action="Index" asp-route-defenceSessionId="@Model.Id">Студенти</a>
    @if (canManageGroups)
    {
        <a class="btn btn-outline-info" asp-controller="AnnualRoles" asp-action="Index" asp-route-defenceSessionId="@Model.Id">Ролі</a>
    }
    <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
    @if (Model.CanArchive)
    {
        <form asp-action="Archive" asp-route-id="@Model.Id" method="post" data-confirm="Заархівувати сесію? Усі зміни будуть заблоковані.">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-warning">Архівувати</button>
        </form>
    }
    <a class="btn btn-link text-secondary" asp-action="Index">До списку</a>
</div>

<h4>Групи</h4>
@if (Model.Groups.Count == 0)
{
    <p class="text-muted">У цій сесії ще немає груп.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Група</th>
            <th>Студентів</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var group in Model.Groups)
        {
            <tr>
                <td>@group.Name</td>
                <td>@group.StudentCount</td>
                <td class="text-end">
                    @if (canManageGroups)
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="StudyGroups" asp-action="Edit" asp-route-id="@group.Id">Редагувати</a>
                        @if (group.CanDelete)
                        {
                            <a class="btn btn-sm btn-outline-danger" asp-controller="StudyGroups" asp-action="Delete" asp-route-id="@group.Id">Видалити</a>
                        }
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
