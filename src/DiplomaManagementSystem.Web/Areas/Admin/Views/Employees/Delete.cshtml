@model DiplomaManagementSystem.Web.Areas.Admin.Models.EmployeeDeleteViewModel
@{
    ViewData["Title"] = "Видалення викладача";
}

<h2>Видалення викладача</h2>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<p>Ви впевнені, що хочете видалити викладача <strong>@Model.FullName</strong> (@Model.Email)?</p>

@if (!Model.CanDelete)
{
    <div class="alert alert-warning">
        <p class="mb-0">Викладача не можна видалити: він пов’язаний із @DefenceWorkLabel.GraduationWorksInstrumental, ролями або записами аудиту.</p>
    </div>
}

@if (Model.CanDelete)
{
    <form asp-action="Delete" method="post" data-confirm="Видалити викладача? Дію не можна скасувати.">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id"/>
        <button type="submit" class="btn btn-danger">Видалити</button>
        <a class="btn btn-link" asp-action="Index">Скасувати</a>
    </form>
}
else
{
    <a class="btn btn-link" asp-action="Index">Назад</a>
}
