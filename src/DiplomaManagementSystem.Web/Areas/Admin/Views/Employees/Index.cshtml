@model DiplomaManagementSystem.Web.Areas.Admin.Models.EmployeeListViewModel
@{
    ViewData["Title"] = "Викладачі";
}

<h2>Викладачі</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Новий викладач</a>
    <a class="btn btn-outline-secondary" asp-controller="Import" asp-action="Employees">Імпорт</a>
</p>

<table class="table table-striped">
    <thead>
    <tr>
        <th>ПІБ</th>
        <th>Email</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.Email</td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
            </td>
        </tr>
    }
    </tbody>
</table>
