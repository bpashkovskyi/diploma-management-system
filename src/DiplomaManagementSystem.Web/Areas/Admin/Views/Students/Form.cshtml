@model DiplomaManagementSystem.Web.Areas.Admin.Models.StudentFormViewModel

@{
    ViewData["Title"] = Model.Id is null ? "Новий студент" : "Редагування студента";
}


<h2>@ViewData["Title"]</h2>

<p class="text-muted">Сесія: @Model.SessionLabel</p>


<form asp-action="@(Model.Id is null ? "Create" : "Edit")" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DefenceSessionId"/>
    @if (Model.Id is not null)

    {
        <input type="hidden" asp-for="Id"/>
    }
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="FullName" class="form-label">ПІБ</label>
        <input asp-for="FullName" class="form-control" maxlength="200"/>
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" maxlength="256"/>
        <span asp-validation-for="Email" class="text-danger"></span>
        <div class="form-text">Окремий обліковий запис для кожної сесії (наприклад, бакалавр і магістр — різні email).</div>
    </div>
    <div class="mb-3">
        <label asp-for="StudyGroupId" class="form-label">Група</label>
        <select asp-for="StudyGroupId" class="form-select" asp-items="Model.StudyGroups">
            <option value="">— оберіть групу —</option>
        </select>
        <span asp-validation-for="StudyGroupId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a class="btn btn-link" asp-action="Index" asp-route-defenceSessionId="@Model.DefenceSessionId">Скасувати</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
