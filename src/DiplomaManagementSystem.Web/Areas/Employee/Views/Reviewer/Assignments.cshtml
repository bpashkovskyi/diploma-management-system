@model ReviewerAssignmentsViewModel
@{
    ViewData["Title"] = EmployeePageTitles.Reviewer;
    PendingCheckpointListViewModel listModel = new()
    {
        Items = Model.Items
            .Select(item => new PendingCheckpointItemViewModel
            {
                DiplomaId = item.DiplomaId,
                StudentFullName = item.StudentFullName,
                StudyGroupName = item.ReviewAssignmentDisplay,
                TopicTitle = item.TopicTitle,
                LatestStudentWork = item.LatestStudentWork,
            })
            .ToList(),        Layout = PendingCheckpointListLayout.Cards,
        FormAction = "Complete",
        EmptyMessage = "Немає призначених рецензій.",
    };
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<partial name="_TempDataAlerts"/>

<p class="mb-3">
    <a asp-area="Employee" asp-controller="Home" asp-action="Index">@EmployeePageTitles.Home</a>
</p>

<partial name="_PendingCheckpointList" model="listModel"/>
