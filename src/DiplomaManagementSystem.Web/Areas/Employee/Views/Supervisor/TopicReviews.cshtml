@model TopicReviewsViewModel
@{
    ViewData["Title"] = EmployeePageTitles.ApproveTopicAsSupervisor;
    var table = new TopicReviewTableViewModel
    {
        Items = Model.Items,
        ApproveButtonText = "Погодити",
        EmptyMessage = "Немає тем на розгляді.",
    };
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<partial name="_TempDataAlerts"/>

<p class="mb-3">
    <a asp-area="Employee" asp-controller="Supervisor" asp-action="Students">@EmployeePageTitles.MyStudents</a>
    ·
    <a asp-area="Employee" asp-controller="Supervisor" asp-action="PendingStudents">@EmployeePageTitles.ConfirmStudentRequest</a>
    ·
    <a asp-area="Employee" asp-controller="Home" asp-action="Index">@EmployeePageTitles.Home</a>
</p>

<partial name="_TopicReviewTable" model="table"/>
