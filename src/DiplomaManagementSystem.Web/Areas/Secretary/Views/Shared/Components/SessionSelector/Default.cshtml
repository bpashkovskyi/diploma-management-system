@model SessionSelectorViewModel

@if (Model.Sessions.Count > 1)
{
    <form asp-area="Secretary" asp-controller="Session" asp-action="Select" method="post" class="row g-2 align-items-end mb-3">
        @Html.AntiForgeryToken()
        <div class="col-auto">
            <label class="form-label mb-0" for="sessionSelector">Сесія:</label>
        </div>
        <div class="col-md-5">
            <select class="form-select form-select-sm" id="sessionSelector" name="sessionId" onchange="this.form.submit()">
                @foreach (var session in Model.Sessions)
                {
                    <option value="@session.Value" selected="@session.Selected">@session.Text</option>
                }
            </select>
        </div>
    </form>
}
else if (Model.Sessions.Count == 1)
{
    <p class="text-muted small mb-3">@Model.Sessions[0].Text</p>
}
