@model DiplomaManagementSystem.Web.Models.AdminPreviewViewModel
@using DiplomaManagementSystem.Web.AdminPreview

@if (Model.IsActivePreview)
{
    <div class="alert alert-warning py-2 mb-3">
        Режим перегляду:
        @if (!string.IsNullOrWhiteSpace(Model.ImpersonatedUserDisplay))
        {
            <strong>@Model.ImpersonatedUserDisplay</strong>
            @if (!string.IsNullOrWhiteSpace(Model.ImpersonatedUserEmail))
            {
                <span class="text-muted">(@Model.ImpersonatedUserEmail)</span>
            }
        }
        else
        {
            <strong>@Model.CurrentModeDisplay</strong>
        }
        @if (Model.RequiresUserSelection && Model.SelectUserMode is not null)
        {
            <span class="ms-2">
                <a asp-controller="AdminPreview" asp-action="SelectUser" asp-route-mode="@Model.SelectUserMode" asp-route-returnUrl="@Model.ReturnUrl">
                    @(string.IsNullOrWhiteSpace(Model.ImpersonatedUserDisplay) ? "Обрати користувача" : "Змінити користувача")
                </a>
            </span>
        }
        <span class="ms-2">
            <form asp-controller="AdminPreview" asp-action="Set" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="mode" value="@AdminPreviewMode.Admin"/>
                <button type="submit" class="btn btn-link btn-sm p-0 align-baseline">Повернутись до адміна</button>
            </form>
        </span>
        <span class="text-muted">. Дії виконуються від імені обраного користувача.</span>
    </div>
}
