@model DiplomaManagementSystem.Web.Models.AdminPreviewViewModel

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-dark d-inline-flex align-items-center gap-2 py-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <span class="text-muted small text-uppercase">Перегляд</span>
        <span class="badge rounded-pill text-bg-primary">@Model.CurrentModeDisplay</span>
    </a>
    <ul class="dropdown-menu dropdown-menu-end">
        @foreach (var option in Model.Options)
        {
            <li>
                <form asp-area="" asp-controller="AdminPreview" asp-action="Set" method="post" class="px-3 py-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="mode" value="@option.Mode"/>
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl"/>
                    <button type="submit" class="dropdown-item@(option.IsSelected ? " active" : string.Empty)">
                        @option.DisplayName
                    </button>
                </form>
            </li>
        }
    </ul>
</li>
