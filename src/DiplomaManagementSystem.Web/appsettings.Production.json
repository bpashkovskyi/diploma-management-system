{
  "FileStorage": {
    "Provider": "Google",
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [ ".pdf", ".docx", ".odt" ],
    "GoogleDrive": {
      "ServiceAccountJsonPath": "/secrets/google-drive-service-account.json",
      "RootFolderId": "",
      "ImpersonateUserEmail": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
